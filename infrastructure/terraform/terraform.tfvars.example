# SchedulSign Terraform Variables
# ================================
# Copy this to terraform.tfvars and fill in your values

# Environment (dev, qa, prod)
environment = "dev"

# AWS Region
aws_region = "us-east-1"

# GitHub Repository
github_repository = "felix-0988/schedulsign"
github_branch     = "main"

# GitHub Access Token (create at https://github.com/settings/tokens)
# Required scopes: repo, admin:repo_hook
github_access_token = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Custom Domain (optional - only for prod)
# domain_name = "app.schedulsign.com"

# Neon PostgreSQL connection string
database_url = "postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Auth.js secret (generate with: openssl rand -base64 32)
auth_secret = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
google_oauth_client_id     = "xxxxxxxxxxxx.apps.googleusercontent.com"
google_oauth_client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx"
